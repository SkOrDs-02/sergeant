// LLM actually needs — every extra property costs tokens on every turn).
const tools: Tool[] = [];

async function executeTool(
  name: string,
  _input: Record<string, unknown>,
): Promise<string> {
  // TODO({{name}}): dispatch on `name` to the matching real implementation.
  return `Unknown tool: ${name}`;
}

export async function run{{pascalName}}Agent(
  client: Anthropic,
  userMessage: string,
): Promise<string> {
  return runAgentLoop(client, userMessage, {
    model: MODEL,
    maxTokens: MAX_TOKENS,
    systemPrompt: SYSTEM_PROMPT,
    tools,
    executeTool,
  });
}
