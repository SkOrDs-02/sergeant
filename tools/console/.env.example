# Sergeant Console (tools/console) — environment variables
# cp .env.example .env   then fill in values
# NEVER commit .env to the repo.
#
# After ADR-0032 the active surface is OpenClaw (@OpenClaw_sergeant_bot).
# Legacy @sergeant_console_bot (ADR-0027) is dormant: setting CONSOLE_BOT_TOKEN
# is OPTIONAL. If unset, only OpenClaw boots.

# ── OpenClaw v0 — co-founder bot (ADR-0031, primary) ──────────
# Telegram bot for founder DM. Long-poll, single-allowlist.
# Bot creation: @BotFather → /newbot → @OpenClaw_sergeant_bot.
# Без token бот НЕ стартує (warn-and-skip, fail-soft).
OPENCLAW_BOT_TOKEN=

# Telegram numeric user_id founder-а (allowlist single-value у Phase 1).
# Витягнути після першого DM до бота:
#   curl https://api.telegram.org/bot<OPENCLAW_BOT_TOKEN>/getUpdates
# Будь-який update від іншого user_id → drop без reply (щоб не leak-ати
# existence бота).
OPENCLAW_FOUNDER_TG_USER_ID=

# Better Auth users.id founder-а (для server-side audit attribution).
OPENCLAW_FOUNDER_USER_ID=

# Limits / governance (мають defaults; override тільки якщо треба).
# OPENCLAW_MAX_ITERATIONS=8
# OPENCLAW_RATE_LIMIT_PER_MIN=10
# OPENCLAW_DAILY_USD_BUDGET=5.0

# Окремий envelope для /council round-table (ADR-0033, Phase 2.5).
# Перевіряється до старту council-сесії: dailySpentUsd + COUNCIL_USD_BUDGET
# не повинен перевищити DAILY_USD_BUDGET. Default $2 щоб одна нарада не
# забрала більш ніж 40% денного $5 cap.
# OPENCLAW_COUNCIL_USD_BUDGET=2.0

# ── OpenClaw webhook delivery (ADR-0041) ──────────────────────
# Default off → long-poll. Локальний dev лишається на long-poll;
# Railway вмикає webhook через `OPENCLAW_USE_WEBHOOK=true`.
# Webhook знижує latency approval-кнопок з 2-3с до <500мс.
# OPENCLAW_USE_WEBHOOK=false
#
# Публічна HTTPS-URL Railway-сервісу + path. Має бути https://.
# OPENCLAW_WEBHOOK_URL=https://sergeant-hubchat.up.railway.app/webhook/openclaw
#
# Shared secret. Telegram echoes у X-Telegram-Bot-Api-Secret-Token header.
# ≥32 chars, /^[A-Za-z0-9_-]+$/. Згенерувати: `openssl rand -hex 24`.
# OPENCLAW_WEBHOOK_SECRET=
#
# Override path якщо стандартний `/webhook/openclaw` зайнятий.
# OPENCLAW_WEBHOOK_PATH=/webhook/openclaw
#
# Tcp port. Railway-провайдиться автоматично через PORT; цей override —
# лише для self-hosted scenarios. Default 8080 коли і PORT, і override unset.
# OPENCLAW_WEBHOOK_PORT=8080

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Sergeant server (для internal API calls) ─────────────────
# Локально — http://localhost:3000. На Railway — http://sergeant.railway.internal:3000.
SERVER_INTERNAL_URL=http://localhost:3000
INTERNAL_API_KEY=

# ── Legacy Sergeant Console (ADR-0027, dormant after ADR-0032) ─
# Залишено в коді на випадок team-mode у майбутньому. Без token гілка
# не стартує (warn-and-skip), OpenClaw піднімається сам.
# CONSOLE_BOT_TOKEN=

# Comma-separated Telegram user IDs allowlist для legacy console-боту.
# Використовується тільки коли CONSOLE_BOT_TOKEN заданий. Get your ID via
# @userinfobot. Empty == allow-all (NOT recommended).
# ALLOWED_USER_IDS=

# ── Server-side ops/marketing tool credentials ────────────────
# Ці tools бачать апі-ключі через apps/server, НЕ через цей процес.
# Тут — лише для довідки і local-dev (apps/server та tools/console
# часто читають один .env у monorepo). Без них tool повертає
# {notConfigured:true} замість fail-loud.
#
# get_stripe_metrics → STRIPE_SECRET_KEY (sk_live_… або sk_test_…)
# STRIPE_SECRET_KEY=
#
# get_sentry_issues → SENTRY_AUTH_TOKEN + SENTRY_ORG (default "sergeant")
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
#
# get_posthog_stats → POSTHOG_API_KEY + POSTHOG_PROJECT_ID
# POSTHOG_API_KEY=
# POSTHOG_PROJECT_ID=
#
# get_github_releases → OPENCLAW_GITHUB_PAT (optional, без — 60 RPH unauth)
#                       OPENCLAW_GITHUB_REPO (default Skords-01/Sergeant)
# OPENCLAW_GITHUB_PAT=
# OPENCLAW_GITHUB_REPO=
