{
  "$schema": "https://app.kilo.ai/config.json",
  "skills": {
    "paths": ["./.agents/skills"]
  },
  "instructions": ["./AGENTS.md", "./CLAUDE.md"],
  "permission": {
    "read": "allow",
    "bash": "allow",
    "edit": {
      "apps/**": "allow",
      "packages/**": "allow",
      "tools/**": "allow",
      "docs/**": "allow",
      "scripts/**": "allow",
      "ops/**": "allow",
      ".github/**": "allow",
      ".husky/**": "allow",
      "*": "ask"
    },
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "task": "allow",
    "question": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "skill": "allow",
    "background_process": "allow",
    "agent_manager": "allow",
    "kilo_local_recall": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true
  }
}
