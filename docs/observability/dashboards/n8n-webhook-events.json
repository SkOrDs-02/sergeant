{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for Sergeant server metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "asDropdown": false,
      "icon": "doc",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "metrics.md (n8n_webhook_replay_*)",
      "tooltip": "Prometheus metrics reference",
      "type": "link",
      "url": "https://github.com/Skords-01/Sergeant/blob/main/docs/observability/metrics.md"
    },
    {
      "asDropdown": false,
      "icon": "doc",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "runbook.md (webhook-replay)",
      "tooltip": "Incident runbook — `webhook-events replay` (PR-28/PR-29)",
      "type": "link",
      "url": "https://github.com/Skords-01/Sergeant/blob/main/docs/observability/runbook.md"
    },
    {
      "asDropdown": false,
      "icon": "doc",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "scripts/replay-webhook.mjs",
      "tooltip": "CLI for triggering replays (PR-29)",
      "type": "link",
      "url": "https://github.com/Skords-01/Sergeant/blob/main/scripts/replay-webhook.mjs"
    }
  ],
  "panels": [
    {
      "title": "Replay success rate (24h)",
      "description": "ok / (ok + http_error + unknown_workflow + timeout + error). Single-stat from n8n_webhook_replay_attempts_total. Green ≥95%, yellow 80-95%, red <80%.",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(increase(n8n_webhook_replay_attempts_total{outcome=\"ok\"}[24h])) / clamp_min(sum(increase(n8n_webhook_replay_attempts_total[24h])), 1)",
          "legendFormat": "success rate (24h)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Replay attempts (24h)",
      "description": "Total replay attempts in last 24h across all workflows and outcomes. Volume context for success-rate panel.",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(increase(n8n_webhook_replay_attempts_total[24h]))",
          "legendFormat": "replays (24h)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Replay failures (24h, by outcome)",
      "description": "Sum of non-ok outcomes — http_error / unknown_workflow / timeout / error. Should be 0 у happy state. Будь-яке стале значення >0 — потенційний DLQ-кандидат, перевірити логи.",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum by (outcome) (increase(n8n_webhook_replay_attempts_total{outcome!=\"ok\"}[24h]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Replay attempts over time (per workflow × outcome)",
      "description": "rate(n8n_webhook_replay_attempts_total[5m]) × 60 — replays per minute. Stack-нуто по workflow + outcome щоб видно куди йдуть replays і де помилки. Sudden burst = incident replay triggered.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 4,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            },
            "lineWidth": 1
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*outcome=\"ok\".*"
            },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "green" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "sum"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (workflow_id, outcome) (rate(n8n_webhook_replay_attempts_total[5m])) * 60",
          "legendFormat": "{{workflow_id}} / {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top workflows by replay count (24h)",
      "description": "Workflows ranked by replay-attempt volume. Top entry = most-frequently-replayed (likely highest-incident-rate webhook). Used for sizing incident-response priority. Table format — sort descending by Value.",
      "type": "table",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 5,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "align": "right",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "workflow_id"
            },
            "properties": [
              {
                "id": "custom.align",
                "value": "left"
              },
              {
                "id": "custom.width",
                "value": 280
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "desc": true,
            "displayName": "Value"
          }
        ],
        "showHeader": true,
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (workflow_id) (increase(n8n_webhook_replay_attempts_total[24h])))",
          "legendFormat": "{{workflow_id}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "Replays (24h)"
            }
          }
        }
      ]
    },
    {
      "title": "Replay latency p50/p95/p99 (per workflow)",
      "description": "histogram_quantile() on n8n_webhook_replay_duration_ms_bucket. p95 >5s → naближається до 10s timeout-у, time-to-degrade — investigate. p99 spikes = транзієнтні n8n delays.",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 6,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "ms",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, workflow_id) (rate(n8n_webhook_replay_duration_ms_bucket[5m])))",
          "legendFormat": "p50 {{workflow_id}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, workflow_id) (rate(n8n_webhook_replay_duration_ms_bucket[5m])))",
          "legendFormat": "p95 {{workflow_id}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, workflow_id) (rate(n8n_webhook_replay_duration_ms_bucket[5m])))",
          "legendFormat": "p99 {{workflow_id}}",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Replay latency heatmap (all workflows)",
      "description": "n8n_webhook_replay_duration_ms_bucket — distribution of per-attempt latency. Healthy: mass below 500ms bucket. Spike toward 5s-10s buckets = pre-timeout zone (n8n або downstream API slow).",
      "type": "heatmap",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "id": 7,
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false,
          "unit": "ms"
        },
        "rowsFrame": {
          "layout": "auto"
        },
        "color": {
          "mode": "scheme",
          "scheme": "Oranges",
          "fill": "dark-orange",
          "steps": 64,
          "exponent": 0.5,
          "min": 0
        },
        "cellGap": 1,
        "filterValues": {
          "le": 1e-9
        },
        "tooltip": {
          "show": true,
          "yHistogram": false
        },
        "legend": {
          "show": true
        },
        "exemplars": {
          "color": "rgba(255,0,255,0.7)"
        }
      },
      "targets": [
        {
          "expr": "sum by (le) (increase(n8n_webhook_replay_duration_ms_bucket[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["sergeant", "n8n", "webhook", "replay"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "Europe/Kyiv",
  "title": "Sergeant — n8n Webhook Events (replay tracking)",
  "uid": "sergeant-n8n-webhook-events",
  "version": 1
}
