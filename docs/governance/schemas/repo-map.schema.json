{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Skords-01/Sergeant/blob/main/docs/governance/schemas/repo-map.schema.json",
  "title": "Sergeant Repo Map (auto-derived)",
  "description": "Machine-readable mirror of `docs/02-engineering/architecture/repo-map.md` — workspaces enumerated from pnpm-workspace.yaml, with stack data parsed from each package.json. Generated by scripts/docs/generate-repo-map.mjs. Acts as drift-detector: the markdown view stays hand-maintained (editorial Purpose column, build/deploy narrative) but every workspace listed here MUST appear in the markdown.",
  "type": "object",
  "required": ["version", "generated_at", "toolchain", "workspaces"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "generated_at": { "type": "string", "format": "date" },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "node": { "type": "string" },
        "pnpm": { "type": "string" },
        "typescript": { "type": "string" },
        "turbo": { "type": "string" }
      }
    },
    "workspaces": {
      "type": "array",
      "items": { "$ref": "#/definitions/workspace" }
    }
  },
  "definitions": {
    "workspaceCategory": {
      "type": "string",
      "enum": ["app", "package", "tool"]
    },
    "workspace": {
      "type": "object",
      "required": ["name", "path", "category"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "category": { "$ref": "#/definitions/workspaceCategory" },
        "private": { "type": "boolean" },
        "version": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["module", "commonjs"]
        },
        "frameworkDeps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "version"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" }
            }
          },
          "description": "Filtered dependency snapshot — only the frameworks/runtimes a human cares about (react, vite, express, expo, capacitor, vitest, jest, …)."
        },
        "testRunner": {
          "type": ["string", "null"],
          "enum": ["vitest", "jest", "node-test", "playwright", "lhci", null],
          "description": "Inferred from `scripts.test` line."
        },
        "owner": {
          "type": ["string", "null"],
          "description": "First CODEOWNERS entry that matches this workspace path."
        }
      }
    }
  }
}
