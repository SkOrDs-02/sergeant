{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Skords-01/Sergeant/blob/main/docs/04-governance/governance/schemas/knowledge-graph.schema.json",
  "title": "Sergeant Knowledge Graph",
  "description": "Unified cross-artifact graph linking ADRs, initiatives, playbooks, skills, hard rules, audits, services, packages, files, and PRs. Generated by scripts/docs/generate-knowledge-graph.mjs.",
  "type": "object",
  "required": ["version", "generated_at", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version; bump on breaking changes."
    },
    "generated_at": {
      "type": "string",
      "format": "date",
      "description": "ISO date the artifact was generated (UTC)."
    },
    "counts": {
      "type": "object",
      "description": "Quick stats keyed by node type. Optional helper for dashboards.",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/definitions/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/definitions/edge" }
    }
  },
  "definitions": {
    "nodeType": {
      "type": "string",
      "enum": [
        "adr",
        "initiative",
        "playbook",
        "skill",
        "hard-rule",
        "audit",
        "service",
        "package",
        "file",
        "pr"
      ]
    },
    "edgeType": {
      "type": "string",
      "enum": [
        "supersedes",
        "references",
        "enforces",
        "documents",
        "owned-by",
        "touched-by"
      ]
    },
    "node": {
      "type": "object",
      "required": ["id", "type", "title"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 3,
          "description": "Stable canonical id, formatted `<type>:<slug>` (e.g. `adr:0045`, `hard-rule:18`, `playbook:add-api-endpoint`, `skill:sergeant-web-ui`)."
        },
        "type": { "$ref": "#/definitions/nodeType" },
        "title": { "type": "string", "minLength": 1 },
        "path": {
          "type": "string",
          "description": "Repo-relative path to the canonical source file, when applicable."
        },
        "status": {
          "type": "string",
          "description": "Raw `> **Status:**` text from the source doc, when present."
        },
        "tier": {
          "type": "string",
          "enum": ["core", "extended"],
          "default": "core",
          "description": "Rendering tier — `core` always shown in HTML viewer; `extended` (symbol-level, files) lazy-loaded."
        },
        "meta": {
          "type": "object",
          "description": "Free-form per-type metadata (e.g. owner, severity, category, last_validated).",
          "additionalProperties": true
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "type"],
      "additionalProperties": false,
      "properties": {
        "from": {
          "type": "string",
          "description": "Source node id (must exist in `nodes`)."
        },
        "to": {
          "type": "string",
          "description": "Target node id (must exist in `nodes`)."
        },
        "type": { "$ref": "#/definitions/edgeType" },
        "meta": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
