{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs"],
      "project": ["scripts/**"]
    },
    "apps/web": {
      "entry": ["src/sw.ts"],
      "project": ["src/**/*.{js,jsx,ts,tsx}"]
    },
    "apps/server": {
      "project": ["src/**/*.{js,ts}"],
      "ignoreDependencies": ["pino-pretty"]
    },
    "apps/mobile": {
      "entry": ["app/**/*.{ts,tsx}", "src/**/*.{ts,tsx}"],
      "project": ["app/**/*.{ts,tsx}", "src/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "sucrase",
        "@babel/preset-typescript",
        "@config-plugins/detox"
      ]
    },
    "apps/mobile-shell": {
      "entry": ["capacitor.config.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/api-client": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/config": {
      "entry": ["*.ts", "*.json"],
      "project": ["**/*"]
    },
    "packages/design-tokens": {
      "entry": ["tokens.js", "tailwind-preset.js"],
      "project": ["**/*.js"]
    },
    "packages/shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreExportsUsedInFile": true
}
