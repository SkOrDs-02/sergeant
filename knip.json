{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs"],
      "project": ["scripts/**"],
      "ignoreDependencies": [
        "@eslint/js",
        "eslint-plugin-jsx-a11y",
        "eslint-plugin-react",
        "eslint-plugin-react-hooks",
        "typescript-eslint",
        "lint-staged",
        "openapi-typescript",
        "tsc-files"
      ]
    },
    "apps/web": {
      "entry": ["src/sw.ts"],
      "project": ["src/**/*.{js,jsx,ts,tsx}"],
      "ignoreDependencies": [
        "@fontsource-variable/dm-sans",
        "@fontsource-variable/jetbrains-mono",
        "@fontsource-variable/manrope"
      ]
    },
    "apps/server": {
      "project": ["src/**/*.{js,ts}"],
      "ignoreDependencies": ["pino-pretty"]
    },
    "apps/mobile": {
      "entry": ["app/**/*.{ts,tsx}", "src/**/*.{ts,tsx}"],
      "project": ["app/**/*.{ts,tsx}", "src/**/*.{ts,tsx}"],
      "ignore": ["metro.config.js"],
      "metro": false,
      "ignoreDependencies": [
        "sucrase",
        "@babel/preset-typescript",
        "@config-plugins/detox"
      ]
    },
    "apps/mobile-shell": {
      "entry": ["capacitor.config.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@capacitor/ios"]
    },
    "packages/api-client": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/config": {
      "entry": ["*.ts", "*.json"],
      "project": ["**/*"]
    },
    "packages/design-tokens": {
      "entry": ["tokens.js", "tailwind-preset.js"],
      "project": ["**/*.js"]
    },
    "packages/db-schema": {
      "ignoreDependencies": ["drizzle-kit"]
    },
    "packages/shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@stryker-mutator/vitest-runner"]
    }
  },
  "ignoreExportsUsedInFile": true
}
