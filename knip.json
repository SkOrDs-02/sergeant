{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  // Suppress categories that generate false positives in this monorepo:
  // - exports/types: intentionally exported for public APIs, test helpers (__reset*), future consumers
  // - duplicates: named + default dual exports are intentional style in many files
  // - unresolved: .js-extension imports (moduleResolution:bundler), build-artifact paths, broken
  //     sync/http/schemas.js refs (pre-existing TS errors on main — not a knip task)
  "exclude": ["exports", "types", "duplicates", "unresolved"],
  // Generated telemetry directory — not a real workspace, contains vitest/@sentry test fixtures
  "ignore": [".telemetry/**"],
  "workspaces": {
    ".": {
      // Expanded from scripts/*.mjs to cover subdirectory scripts (ci/, claude-hooks/,
      // codemods/, docs/, flaky-tests/) and .ts files (flaky-tests/vitest.config.ts).
      "entry": ["scripts/**/*.{mjs,ts}"],
      "project": ["scripts/**"],
      "ignoreDependencies": [
        "@eslint/js",
        "eslint-plugin-jsx-a11y",
        "eslint-plugin-react",
        "eslint-plugin-react-hooks",
        "typescript-eslint",
        "lint-staged",
        "openapi-typescript",
        "tsc-files",
        // globals — imported in eslint.baseline.js (detected via eslint knip plugin); not in entry
        "globals",
        // @commitlint/types — used in commitlint.config.js (detected via commitlint plugin)
        "@commitlint/types",
        // vitest — used in scripts/ci/*.mjs, scripts/flaky-tests/aggregate.test.ts,
        //          tools/tsconfig-guard/__tests__/check.test.mjs (no package.json → root workspace)
        "vitest",
        // semver — used in scripts/check-pnpm-overrides.mjs
        "semver",
        // pg — used in scripts/db-index-audit.mjs, scripts/migration-down-drill.mjs,
        //      scripts/seed-strategic-goals.mjs
        "pg"
      ]
    },
    "apps/web": {
      "entry": ["src/sw.ts"],
      "project": ["src/**/*.{js,jsx,ts,tsx}"],
      // Scaffolded module barrels — all carry @scaffolded + @nextStep markers per AGENTS.md
      // Hard Rule #10. Do NOT delete; wire the barrel consumers in follow-up PRs.
      "ignore": [
        "src/core/cloudSync/index.ts",
        "src/core/errors/index.ts",
        "src/core/profile/index.ts",
        "src/modules/finyk/index.ts",
        "src/modules/fizruk/index.ts",
        "src/modules/nutrition/index.ts",
        "src/modules/routine/index.ts",
        "src/shared/forms/index.ts",
        "src/shared/lib/insights/index.ts"
      ],
      "ignoreDependencies": [
        "@fontsource-variable/dm-sans",
        "@fontsource-variable/jetbrains-mono",
        "@fontsource-variable/manrope",
        // better-sqlite3 — used in dualWrite/__tests__/testSqlite.ts files; not in web package.json
        "better-sqlite3",
        // @testing-library/user-event — used in nutrition page tests; not in web package.json
        "@testing-library/user-event",
        // @tanstack/query-persist-client-core — sub-path of @tanstack/react-query-persist-client
        "@tanstack/query-persist-client-core"
      ]
    },
    "apps/server": {
      "project": ["src/**/*.{js,ts}"],
      // Scaffolded server barrels — all carry @scaffolded + @nextStep markers.
      "ignore": [
        "src/lib/ragEval/index.ts",
        "src/modules/ai-memory/index.ts",
        "src/modules/billing/index.ts"
      ],
      "ignoreDependencies": [
        "pino-pretty",
        // pino-loki — used as string reference `target: "pino-loki"` in lokiTransport.ts,
        //   not an ES import; added in 03f1596db (feat: loki transport). Confirmed real infra.
        "pino-loki",
        // @better-auth/core — used via deep path @better-auth/core/db/adapter; transitive dep
        "@better-auth/core"
      ]
    },
    "apps/mobile": {
      "entry": ["app/**/*.{ts,tsx}", "src/**/*.{ts,tsx}"],
      "project": ["app/**/*.{ts,tsx}", "src/**/*.{ts,tsx}"],
      "metro": false,
      "ignoreDependencies": [
        "@babel/preset-typescript",
        "@config-plugins/detox",
        // expo-updates, expo-system-ui — detected by knip Expo plugin from app.config.ts;
        //   these are implicit Expo runtime deps, not direct imports
        "expo-updates",
        "expo-system-ui",
        // drizzle-orm — used in db/__tests__/sqlite.test.ts and db/sqlite.ts;
        //   hoisted from workspace but not declared in apps/mobile/package.json
        "drizzle-orm"
      ]
    },
    "apps/mobile-shell": {
      "project": ["src/**/*.{ts,tsx}"],
      // @capacitor/ios is consumed by the Capacitor CLI (`cap add/sync/open ios`,
      // see add:ios/build:ios/open:ios scripts), not via JS imports, and there is
      // no ios/ native project yet — so knip cannot see it. Kept for iOS-readiness
      // (version-locked with the other @capacitor/* deps). Knip false-positive.
      "ignoreDependencies": ["@capacitor/ios"]
    },
    "packages/api-client": {
      "project": ["src/**/*.{ts,tsx}"],
      // jsdom — used via // @vitest-environment jsdom directive in test files;
      //   not declared in api-client/package.json (hoisted)
      "ignoreDependencies": ["jsdom"]
    },
    "packages/config": {
      "entry": ["*.ts", "*.json"],
      "project": ["**/*"],
      // vitest — used via vitest/config sub-path in vitest.base.js;
      //   not declared in packages/config/package.json
      "ignoreDependencies": ["vitest"]
    },
    "packages/design-tokens": {
      "project": ["**/*.js"],
      // tailwindcss — used in tailwind-preset.js; not declared in packages/design-tokens/package.json
      "ignoreDependencies": ["tailwindcss"]
    },
    "packages/eslint-plugin-sergeant-design": {
      // @typescript-eslint/parser — used directly in __tests__/no-strict-bypass.test.mjs;
      //   package has no package.json dependencies at all (hoisted from root)
      "ignoreDependencies": ["@typescript-eslint/parser"]
    },
    "packages/finyk-domain": {
      // jsdom — used via // @vitest-environment jsdom in transactions.test.ts (hoisted)
      "ignoreDependencies": ["jsdom"]
    },
    "packages/openclaw-plugin": {
      // Scaffolded parity barrel — @scaffolded + @nextStep; tracked in dead-code roast 2026-05-13.
      // Do NOT delete; future smoke-suite / integration suite will import from it.
      "ignore": ["src/parity/index.ts"],
      // openclaw/plugin-sdk/plugin-entry — provided by the OpenClaw runtime at execution time,
      //   not a pnpm dependency (similar to how plugin host APIs are provided by the host)
      // typebox — used in index.ts but not declared in package.json (transitive from zod)
      "ignoreDependencies": ["openclaw", "typebox"]
    },
    "packages/shared": {
      "project": ["src/**/*.ts"],
      // kvStore.ts — @deprecated re-export barrel; @removeBy 2026-09-01; zero real importers
      //   (check-kvstore-deep-imports tests the lint rule against this path, not an actual import)
      "ignore": ["src/lib/kvStore.ts"],
      "ignoreDependencies": [
        "@stryker-mutator/vitest-runner",
        // jsdom — used via // @vitest-environment jsdom in deepLinkChannel.test.ts (hoisted)
        "jsdom"
      ]
    }
  },
  "ignoreExportsUsedInFile": true
}
