{
  "name": "@sergeant/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./utils": "./src/utils/index.ts",
    "./types": "./src/types/index.ts",
    "./openapi": "./src/openapi/index.ts",
    "./test-utils": "./src/test-utils.ts",
    "./lib/pii": "./src/lib/pii.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "cross-env TZ=Europe/Kyiv vitest run",
    "test:watch": "cross-env TZ=Europe/Kyiv vitest",
    "test:coverage": "cross-env TZ=Europe/Kyiv vitest run --coverage",
    "mutation:utils": "cross-env TZ=Europe/Kyiv stryker run stryker.utils.conf.json"
  },
  "dependencies": {
    "@sergeant/design-tokens": "workspace:*",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@sergeant/config": "workspace:*",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^20.19.41",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
