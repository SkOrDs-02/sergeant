{
  "extends": "@sergeant/config/tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "noUncheckedIndexedAccess": true,
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "rootDir": "./src",
    "outDir": "./dist",
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
