{
  "$schema": "https://openclaw.ai/schema/plugin.json",
  "id": "sergeant",
  "name": "Sergeant",
  "description": "Sergeant agent gateway plugin (Stage 2 — 25 read tools, no hooks yet)",
  "version": "1.0.0-stage2",
  "entry": "./dist/index.js",
  "activation": { "onStartup": true },
  "contracts": {
    "tools": [
      "recall_memory",
      "read_strategy_docs",
      "record_decision",
      "query_app_db",
      "get_server_stats",
      "get_stripe_metrics",
      "get_posthog_stats",
      "get_sentry_issues",
      "read_github",
      "github_search",
      "github_tree",
      "github_diff",
      "github_prs",
      "get_github_releases",
      "n8n_list",
      "n8n_describe",
      "n8n_trigger",
      "n8n_activate",
      "refresh_business_snapshot",
      "read_workflow_logs",
      "read_telegram_topic",
      "seo_gsc_query",
      "seo_psi_audit",
      "seo_serp_lookup",
      "set_reminder"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "serverInternalUrl": { "type": "string" },
      "internalApiKey": { "type": "string" },
      "founderUserId": { "type": "string" },
      "maxPerCallUsd": { "type": ["string", "number"] },
      "councilUsdBudget": { "type": ["string", "number"] },
      "approvalVariant": { "type": "string", "enum": ["A", "B", "C"] },
      "cheapRouterSystemPromptPath": { "type": "string" }
    },
    "required": ["serverInternalUrl", "internalApiKey", "founderUserId"]
  }
}
