            "create_github_issue",
            "mute_alert",
            "pause_workflow",
            "post_to_topic"
          ]
        }
      }
    ]
  },

  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "controlUi": { "enabled": false, "allowInsecureAuth": false },
    "auth": { "mode": "token", "token": "${OPENCLAW_GATEWAY_AUTH_TOKEN}" },
    "tailscale": { "mode": "off", "resetOnExit": false },
    "canvasHost": {
      "advertisedUrl": "https://${RAILWAY_PUBLIC_DOMAIN}"
    }
  },

  "session": { "dmScope": "per-channel-peer" },
  "tools": {
    "profile": "coding",
    "alsoAllow": ["recall_memory", "canvas"]
  },

  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 1,
    "retry": {
      "maxAttempts": 3,
      "backoffMs": [60000, 120000, 300000],
      "retryOn": ["rate_limit", "overloaded", "network", "server_error"]
    },
    "sessionRetention": "24h",
    "failureAlert": {
      "enabled": true,
      "after": 1,
      "cooldownMs": 3600000,
      "mode": "announce"
    }
  },

  "plugins": {
    "bundledDiscovery": "compat",
    "allow": ["sergeant"],
    "entries": {
      "anthropic": { "enabled": true },
      "telegram": { "enabled": true },
      "sergeant": {
        "enabled": true,
        "hooks": {
          "allowConversationAccess": true
        },
        "config": {
          "serverInternalUrl": "${SERVER_INTERNAL_URL}",
          "internalApiKey": "${INTERNAL_API_KEY}",
          "founderUserId": "${OPENCLAW_FOUNDER_USER_ID}",
          "maxPerCallUsd": "${OPENCLAW_MAX_PER_CALL_USD:-0.5}",
          "councilUsdBudget": "${OPENCLAW_COUNCIL_USD_BUDGET:-2.0}",
          "approvalVariant": "B",
          "cheapRouterSystemPromptPath": "/root/.openclaw/cheap-router.system.md"
        }
      }
    }
  },

  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "api_key"
      }
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${OPENCLAW_GATEWAY_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["${OPENCLAW_FOUNDER_TG_USER_ID}"],
      "groupPolicy": "disabled"
    }
  },

  "meta": {
    "lastTouchedVersion": "2026.5.7"
  }
}
