            "get_posthog_stats",
            "get_stripe_metrics",
            "get_server_stats",
            "recall_memory",
            "canvas"
          ],
          "deny": [
            "commit_to_strategy_doc",
            "create_github_issue",
            "mute_alert",
            "pause_workflow",
            "post_to_topic"
          ]
        }
      },
      {
        "id": "cs",
        "tools": {
          "alsoAllow": [
            "read_telegram_topic",
            "query_app_db",
            "get_posthog_stats",
            "recall_memory",
            "post_to_topic"
          ],
          "deny": [
            "commit_to_strategy_doc",
            "create_github_issue",
            "mute_alert",
            "pause_workflow"
          ]
        }
      },
      {
        "id": "content",
        "tools": {
          "alsoAllow": [
