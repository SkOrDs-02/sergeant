            "n8n_describe",
            "n8n_trigger",
            "n8n_activate",
            "get_sentry_issues",
            "get_server_stats",
            "recall_memory",
            "mute_alert",
            "pause_workflow"
          ],
          "deny": [
            "commit_to_strategy_doc",
            "create_github_issue",
            "post_to_topic"
          ]
        }
      },
      {
        "id": "pm",
        "tools": {
          "alsoAllow": [
            "read_strategy_docs",
            "get_posthog_stats",
            "query_app_db",
            "recall_memory",
            "record_decision",
            "create_github_issue",
            "commit_to_strategy_doc",
            "canvas"
          ],
          "deny": ["mute_alert", "pause_workflow", "post_to_topic"]
        }
      },
      {
        "id": "growth",
        "tools": {
          "alsoAllow": [
            "get_posthog_stats",
            "get_stripe_metrics",
            "query_app_db",
            "read_github",
            "get_github_releases",
            "recall_memory",
            "post_to_topic",
            "canvas"
          ],
          "deny": [
            "commit_to_strategy_doc",
            "create_github_issue",
            "mute_alert",
            "pause_workflow"
          ]
        }
      },
      {
        "id": "finance",
        "tools": {
          "alsoAllow": [
            "get_stripe_metrics",
            "query_app_db",
            "recall_memory",
            "record_decision",
            "canvas"
          ],
          "deny": [
            "commit_to_strategy_doc",
            "create_github_issue",
            "mute_alert",
            "pause_workflow",
            "post_to_topic"
          ]
        }
      },
      {
        "id": "data",
        "tools": {
          "alsoAllow": [
