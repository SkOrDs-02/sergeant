        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"callback_query_id\": \"{{ $('Build snooze edited message').item.json.callbackQueryId }}\",\n  \"text\": \"{{ $('Build snooze edited message').item.json.snoozeOk ? ('Snoozed ' + $('Build snooze edited message').item.json.hoursLabel) : 'Snooze failed' }}\",\n  \"cache_time\": 5\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true,
              "fullResponse": false
            }
          }
        }
      },
      "id": "answer-snooze-cb",
      "name": "Telegram answerCallbackQuery (snooze)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 420],
