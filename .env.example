# ─────────────────────────────────────────────────────────────
# Sergeant Hub — мінімальний `.env` для `pnpm dev:web`+`pnpm dev:server`
# Скопіюйте у `.env` (НЕ комітьте). Повний reference + усі опційні
# змінні (Mono, Sentry, PostHog, Voyage, OpenClaw, AI quota …):
# → docs/integrations/env-vars.md
# ─────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://hub:hub@localhost:5432/hub
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change_me_to_a_long_random_string_32chars
# BETTER_AUTH_TOKEN_ENC_KEY=  # ⚠ prod required — OAuth tokens stored plaintext without this; generate: openssl rand -hex 32
# NUTRITION_BACKUP_KEY_SECRET=  # ⚠ prod required — /api/nutrition/backup-* returns 503 without this; generate: openssl rand -hex 32
# POSTHOG_API_KEY=phx_…        # ⚠ prod required — server-side GDPR cleanup + n8n WF-16/60/63 daily metrics. Personal API key, scopes: project:read, query:read
# POSTHOG_PROJECT_ID=12345     # ⚠ prod required — numeric PostHog project id (Settings → Project → ID); used by GDPR cleanup + n8n WF-16
# POSTHOG_HOST=https://eu.i.posthog.com  # optional override — defaults to EU Cloud; US: https://us.i.posthog.com
# MONO_AI_MEMORY_DIGEST_ENABLED=  # ⚠ prod required — n8n WF-30 daily AI-memory digest gate; виставити `true` у n8n Railway env та flip workflow toggle у n8n UI. Default `false` keeps WF-30 dormant навіть якщо JSON задеплоїлось.
# INTERNAL_API_KEY=               # ⚠ prod required — bearer token for `/api/internal/*` (n8n machine-to-machine). Generate: openssl rand -hex 32
# WEBHOOK_HMAC_SECRET=            # ⚠ prod recommended — HMAC-SHA256 shared secret on top of INTERNAL_API_KEY. Generate: openssl rand -hex 32. Empty disables HMAC verify (bearer-only).
# WEBHOOK_HMAC_REQUIRED=false     # 30-day grace window after first roll-out; flip to `true` once every n8n workflow signs (manifest.json hmac_signed: true).
# WEBHOOK_HMAC_TS_TOLERANCE_SEC=300  # X-Timestamp replay window, seconds. 5min default matches Stripe/GitHub/Slack webhook signatures.
ANTHROPIC_API_KEY=change_me_to_your_anthropic_api_key
USDA_FDC_API_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com
API_SECRET=change_me_to_a_random_string
ALLOWED_ORIGINS=http://localhost:5173
PORT=3000
VITE_API_PROXY_TARGET=http://127.0.0.1:3000
