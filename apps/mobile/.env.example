# Базовий URL API. Для локального запуску на пристрої вкажи IP твоєї машини
# (Expo dev-сервер Metro недоступний із `localhost` із фізичного телефона).
# Для симулятора/емулятора `http://localhost:5000` працює.
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# PostHog для mobile (FTUX activation funnel парний до web —
# див. `docs/launch/ftux-sprint-plan.md` §S0.3). Без ключа транспорт
# повністю no-op, події летять тільки в `console.log("[analytics]", …)`.
# Той самий project key, що й `VITE_POSTHOG_KEY` у root `.env.example`.
# EXPO_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
