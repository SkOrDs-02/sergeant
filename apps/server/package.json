{
  "name": "@sergeant/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/index.js",
    "build": "node build.mjs",
    "start": "node dist-server/index.js",
    "start:replit": "SERVER_MODE=replit node --import tsx src/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node dist-server/migrate.js",
    "db:migrate:dev": "node --import tsx ./migrate.mjs"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.5",
    "@better-auth/expo": "^1.6.5",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/core": "^1.30.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@parse/node-apn": "^8.1.0",
    "@sentry/node": "^8.55.1",
    "@sergeant/db-schema": "workspace:^",
    "@sergeant/finyk-domain": "workspace:*",
    "@sergeant/shared": "workspace:*",
    "@types/compression": "^1.8.1",
    "better-auth": "^1.6.4",
    "bullmq": "^5.0.0",
    "compression": "^1.8.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.22.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sergeant/config": "workspace:*",
    "@types/express": "^4.17.25",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "20.x"
  }
}
