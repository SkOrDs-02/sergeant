{
  "name": "@sergeant/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx src/index.js",
    "build": "node build.mjs",
    "start": "node dist-server/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node dist-server/migrate.js",
    "db:migrate:dev": "node --import tsx ./migrate.mjs",
    "reencrypt:tokens": "node --env-file-if-exists=.env --import tsx scripts/token-reencrypt-rollover.ts",
    "eval:models": "node --env-file-if-exists=.env --import tsx scripts/model-eval.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@better-auth/expo": "^1.6.20",
    "@parse/node-apn": "^8.1.0",
    "@sentry/node": "^8.55.1",
    "@sergeant/db-schema": "workspace:^",
    "@sergeant/finyk-domain": "workspace:*",
    "@sergeant/shared": "workspace:*",
    "@types/compression": "^1.8.1",
    "better-auth": "^1.6.23",
    "bullmq": "^5.80.1",
    "compression": "^1.8.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "pgsql-ast-parser": "^12.0.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-loki": "^2.6.0",
    "prom-client": "^15.1.3",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sergeant/config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.10",
    "ajv": "^8.20.0",
    "esbuild": "^0.28.1",
    "fast-check": "^3.23.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "22.x"
  }
}
