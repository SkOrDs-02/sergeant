{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_": "Mutation testing config focused on cloudSync queue state-machine — second critical surface after conflict resolver. Queue mutations cause silent retry/dead-letter mishandling and offline-replay drift. See docs/testing/mutation.md.",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.js"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/core/cloudSync/queue/collectQueued.ts",
    "src/core/cloudSync/queue/deadLetter.ts",
    "src/core/cloudSync/queue/offlineQueue.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 60
  },
  "reporters": ["clear-text", "progress", "html"],
  "htmlReporter": {
    "fileName": "stryker-reports/cloudSyncQueue.html"
  },
  "tempDirName": "stryker-tmp/cloudSyncQueue",
  "concurrency": 4,
  "timeoutMS": 10000,
  "disableTypeChecks": "{src,test}/**/*.{ts,tsx}",
  "ignoreStatic": true
}
