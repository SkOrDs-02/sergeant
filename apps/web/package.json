{
  "name": "@sergeant/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --host 0.0.0.0",
    "build": "vite build",
    "build:capacitor": "cross-env VITE_TARGET=capacitor vite build",
    "build:analyze": "cross-env ANALYZE=1 vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.sw.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "playwright test",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "e2e:auth": "playwright test --config playwright.smoke.config.ts --grep @auth",
    "size": "size-limit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "size-limit": [
    {
      "name": "JS (усього)",
      "path": "../server/dist/assets/*.js",
      "brotli": true,
      "limit": "820 kB"
    },
    {
      "name": "CSS",
      "path": "../server/dist/assets/*.css",
      "brotli": true,
      "limit": "28 kB"
    }
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/react": "^8.55.1",
    "@sergeant/api-client": "workspace:*",
    "@sergeant/design-tokens": "workspace:*",
    "@sergeant/finyk-domain": "workspace:*",
    "@sergeant/fizruk-domain": "workspace:*",
    "@sergeant/insights": "workspace:*",
    "@sergeant/mobile-shell": "workspace:*",
    "@sergeant/nutrition-domain": "workspace:*",
    "@sergeant/routine-domain": "workspace:*",
    "@sergeant/shared": "workspace:*",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build8",
    "@tanstack/query-async-storage-persister": "^5.99.2",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-persist-client": "^5.99.2",
    "@vercel/analytics": "^2.0.1",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "better-auth": "^1.6.4",
    "body-highlighter": "^3.0.2",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "idb-keyval": "^6.2.2",
    "posthog-js": "^1.372.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.75.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.14.1",
    "react-virtuoso": "^4.18.5",
    "tailwind-merge": "^2.6.0",
    "web-vitals": "^5.2.0",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@argos-ci/playwright": "^6.6.4",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@sentry/vite-plugin": "^5.2.0",
    "@sergeant/config": "workspace:*",
    "@sergeant/db-schema": "workspace:^",
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "msw": "^2.14.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^12.1.0",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "20.x"
  }
}
