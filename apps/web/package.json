{
  "name": "@sergeant/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --host 0.0.0.0",
    "build": "vite build",
    "build:capacitor": "cross-env VITE_TARGET=capacitor vite build",
    "build:analyze": "cross-env ANALYZE=1 vite build",
    "preview": "vite preview",
    "preview:lhci": "vite preview --port 4173 --strictPort --host 127.0.0.1",
    "lighthouse": "lhci autorun --config=lighthouserc.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.sw.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "playwright test",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "e2e:auth": "playwright test --config playwright.smoke.config.ts --grep @auth",
    "e2e": "playwright test --config playwright.smoke.config.ts --grep @critical",
    "e2e:mobile": "playwright test --config playwright.mobile.config.ts",
    "size": "size-limit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "size-limit": [
    {
      "name": "JS (усього)",
      "path": "../server/dist/assets/*.js",
      "brotli": true,
      "limit": "1.25 MB"
    },
    {
      "name": "CSS",
      "path": "../server/dist/assets/*.css",
      "brotli": true,
      "limit": "37 kB"
    }
  ],
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/react": "^8.55.1",
    "@sergeant/api-client": "workspace:*",
    "@sergeant/db-schema": "workspace:*",
    "@sergeant/design-tokens": "workspace:*",
    "@sergeant/dualwrite-core": "workspace:*",
    "@sergeant/finyk-domain": "workspace:*",
    "@sergeant/fizruk-domain": "workspace:*",
    "@sergeant/insights": "workspace:*",
    "@sergeant/mobile-shell": "workspace:*",
    "@sergeant/nutrition-domain": "workspace:*",
    "@sergeant/routine-domain": "workspace:*",
    "@sergeant/shared": "workspace:*",
    "@sqlite.org/sqlite-wasm": "3.51.2-build9",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "@tanstack/react-virtual": "^3.13.12",
    "@vercel/analytics": "^2.0.1",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "better-auth": "^1.6.23",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "posthog-js": "^1.399.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^2.6.0",
    "web-vitals": "^5.3.0",
    "workbox-cacheable-response": "^7.4.0",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@argos-ci/playwright": "^6.6.4",
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@sentry/vite-plugin": "^5.4.0",
    "@sergeant/config": "workspace:*",
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "fake-indexeddb": "^6.2.5",
    "fast-check": "^3.23.2",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^12.1.0",
    "storybook": "^10.5.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "22.x"
  }
}
