{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_": "Mutation testing config focused on cloudSync conflict-resolver — the most critical pure-logic surface in the app (LWW resolution, dirty-skip safety, version compare). See docs/testing/mutation.md for rationale.",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.js"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/core/cloudSync/conflict/parseDate.ts",
    "src/core/cloudSync/conflict/pushSuccess.ts",
    "src/core/cloudSync/conflict/resolver.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 60
  },
  "reporters": ["clear-text", "progress", "html"],
  "htmlReporter": {
    "fileName": "stryker-reports/cloudSync.html"
  },
  "tempDirName": "stryker-tmp/cloudSync",
  "concurrency": 4,
  "timeoutMS": 10000,
  "disableTypeChecks": "{src,test}/**/*.{ts,tsx}",
  "ignoreStatic": true
}
