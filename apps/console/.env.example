# Sergeant Console — environment variables
# cp .env.example .env   then fill in values
# NEVER commit .env to the repo.

# ── Telegram ──────────────────────────────────────────────────
# Create bot via @BotFather → /newbot
CONSOLE_BOT_TOKEN=

# Comma-separated list of Telegram user IDs allowed to use the console.
# Get your ID by messaging @userinfobot.
# Leave empty to allow all users (NOT recommended for production).
ALLOWED_USER_IDS=

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Sergeant server (for internal API calls) ─────────────────
SERVER_INTERNAL_URL=http://localhost:3000
INTERNAL_API_KEY=

# ── OpenClaw v0 — co-founder bot (ADR-0031) ──────────────────
# Окремий Telegram bot для founder DM (не змішується з Sergeant Console).
# Bot creation: @BotFather → /newbot → @OpenClaw_sergeant_bot.
# Без token бот НЕ стартує (fail-closed); apps/console/src/index.ts
# логує "OpenClaw bot disabled" і піднімає лише Sergeant Console.
# OPENCLAW_BOT_TOKEN=

# Telegram numeric user_id founder-а (allowlist single-value у Phase 1).
# Витягнути після першого DM до бота:
#   curl https://api.telegram.org/bot<OPENCLAW_BOT_TOKEN>/getUpdates
# Будь-який update від іншого user_id → drop без reply (щоб не leak-ати
# existence бота).
# OPENCLAW_FOUNDER_TG_USER_ID=

# Per-message rate limit для OpenClaw (fixed window, секунди). Default 60s.
# Захищає від AI-budget-exhaustion при спам-DM.
# OPENCLAW_RATE_LIMIT_PER_MIN=10

# ── Optional: external integrations ──────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# POSTHOG_API_KEY=
# POSTHOG_PROJECT_ID=
